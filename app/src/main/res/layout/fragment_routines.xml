<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/slate_950">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="20dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center_vertical"
            android:orientation="horizontal">

            <ImageButton
                android:id="@+id/backButton"
                android:layout_width="44dp"
                android:layout_height="44dp"
                android:background="@drawable/bg_search_field"
                android:contentDescription="@string/routines_back"
                android:padding="10dp"
                android:src="@drawable/ic_arrow_left"
                app:tint="@color/slate_200" />

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginStart="12dp"
                android:layout_weight="1"
                android:text="@string/routines_title"
                android:textColor="@android:color/white"
                android:textSize="28sp"
                android:textStyle="bold" />
        </LinearLayout>

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="10dp"
            android:text="@string/routines_subtitle"
            android:textColor="@color/slate_200"
            android:textSize="16sp" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/createRoutineButton"
            android:layout_width="match_parent"
            android:layout_height="52dp"
            android:layout_marginTop="18dp"
            android:text="@string/routines_create"
            android:textAllCaps="false"
            app:cornerRadius="8dp" />

        <LinearLayout
            android:id="@+id/emptyRoutinesState"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="64dp"
            android:gravity="center"
            android:orientation="vertical">

            <ImageView
                android:layout_width="58dp"
                android:layout_height="58dp"
                android:src="@drawable/ic_dumbbell" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="18dp"
                android:gravity="center"
                android:text="@string/routines_empty_title"
                android:textColor="@android:color/white"
                android:textSize="22sp"
                android:textStyle="bold" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:gravity="center"
                android:text="@string/routines_empty_subtitle"
                android:textColor="@color/slate_300"
                android:textSize="16sp" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/emptyCreateRoutineButton"
                style="@style/Widget.MaterialComponents.Button.OutlinedButton"
                android:layout_width="match_parent"
                android:layout_height="50dp"
                android:layout_marginTop="22dp"
                android:text="@string/routines_create"
                android:textAllCaps="false"
                android:textColor="@color/slate_200"
                app:cornerRadius="8dp"
                app:strokeColor="@color/teal_300" />
        </LinearLayout>

        <LinearLayout
            android:id="@+id/routineListContainer"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="18dp"
            android:orientation="vertical" />
    </LinearLayout>
</ScrollView>
